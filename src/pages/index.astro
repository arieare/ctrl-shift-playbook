---
import PageShell from "../components/PageShell.astro";
import PlaybookSection from "../components/PlaybookSection.astro";
import PrintTableOfContents from "../components/PrintTableOfContents.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { getCollection, render } from "astro:content";
import "../styles/reset.css";
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/typography.css";
import "../styles/layout.css";
import "../styles/components.css";
import "../styles/print.css";

const rawSections = await getCollection("playbook");

const slugifyHeading = (value: string) => {
  return value
    .toLowerCase()
    .replace(/[^\p{Letter}\p{Number}]+/gu, "-")
    .replace(/^-+|-+$/g, "");
};

const getPrintHeadings = (sectionId: string, body: string) => {
  return Array.from(body.matchAll(/^##\s+(?!#)(.+)$/gm)).map((match, index) => {
    const label = match[1]?.trim() ?? "";

    return {
      id: `${sectionId}-${slugifyHeading(label) || "heading"}-${index + 1}`,
      label,
    };
  });
};

const sections = await Promise.all(
  rawSections.map(async (section) => {
    const { Content } = await render(section);
    const id = section.id.replace(/\.md$/, "").replace(/^\d+-/, "");

    return {
      id,
      title: section.data.title,
      navLabel: section.data.navLabel ?? section.data.title,
      summary: section.data.summary,
      order: section.data.order,
      headings: getPrintHeadings(id, section.body),
      Content,
    };
  }),
).then((entries) => entries.sort((a, b) => a.order - b.order));

const title = "Ctrl+Shift! Playbook";
const description = "A living playbook documenting Ctrl+Shift! discussions among researchers in Indonesia.";
---

<PageShell title={title} description={description}>
  <a class="skip-link" href="#playbook">Skip to playbook</a>

  <header class="landing-hero" data-hero>
    <canvas class="landing-hero__gradient" data-hero-gradient aria-hidden="true"></canvas>
    <div class="landing-hero__inner">
      
      <h1 class=hidden>Ctrl+Shift! Playbook</h1>
      <img src="images/ctrl-shift-playbook-logo.png" alt="Ctrl+Shift! Playbook" style="width:300px;"/>
      <div class="landing-hero__actions" aria-label="Playbook actions">
        <a class="button" href="#playbook">Read the Playbook</a>
        <button class="button button--secondary" type="button" data-print-button><i class="fa-solid fa-download"></i> Download PDF</button>
      </div>
    </div>
  </header>

  <header class="site-header" aria-label="Site header" data-site-header aria-hidden="true">
    <div class="site-header__inner">
      <a class="site-header__logo" href="#playbook">
      <img src="images/ctrl-shift-logo.png" style="max-height:56px"></a>
      <div class="site-header__actions">
        <form class="site-search" role="search" data-site-search>
          <label class="visually-hidden" for="site-search-input">Search playbook</label>
          <button
            class="site-search__trigger"
            type="button"
            aria-label="Search playbook"
            aria-controls="site-search-input"
            aria-expanded="false"
            data-search-trigger
          >
            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
          </button>
          <input
            class="site-search__input"
            id="site-search-input"
            type="search"
            placeholder="Search playbook"
            autocomplete="off"
            aria-controls="site-search-results"
            aria-expanded="false"
            data-search-input
          />
          <span class="site-search__shortcut" aria-hidden="true">⌘K</span>
          <div class="site-search__results" id="site-search-results" data-search-results hidden></div>
        </form>
        <button class="button" type="button" aria-label="Download PDF" data-print-button>
          <i class="fa-solid fa-download" aria-hidden="true"></i>
          <span class="button__label">Download PDF</span>
        </button>
      </div>
    </div>
  </header>

  <main class="page-shell" id="playbook">
    <aside class="page-shell__nav">
      <TableOfContents items={sections} />
    </aside>

    <article class="page-shell__content" aria-labelledby="playbook-title">
      <h2 class="visually-hidden" id="playbook-title">Playbook content</h2>
      <PrintTableOfContents items={sections} />

      <div class="section-stack">
        {
          sections.map((section) => (
            <PlaybookSection
              id={section.id}
              title={section.title}
              summary={section.summary}
              Content={section.Content}
            />
          ))
        }
      </div>
    </article>
  </main>

  <footer class="site-footer" aria-label="Site license">
    <div class="site-footer__inner">
      <nav class="site-footer__links" aria-label="Ctrl+Shift links">
        <a href="https://www.instagram.com/ctrlshift_id/?hl=en" rel="noreferrer" target="_blank"><i class="fa-brands fa-instagram"></i> @ctrlshift_id</a>
      </nav>
      <div class="site-footer__license">
        <div class="license-icons" aria-hidden="true">
          <i class="fa-brands fa-creative-commons"></i>
          <i class="fa-brands fa-creative-commons-by"></i>
          <i class="fa-brands fa-creative-commons-nc"></i>
          <i class="fa-brands fa-creative-commons-sa"></i>
        </div>
        <p>
          Except where otherwise noted, content on this site is licensed under a
          <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International license (CC BY-NC-SA 4.0)</a>.
        </p>
      </div>
    </div>
  </footer>

  <script>
    import "../scripts/hero-mesh-gradient.ts";
    import "../scripts/playbook.ts";
  </script>
</PageShell>
